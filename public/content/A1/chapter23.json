  "grammar": [
    {
      "topic": "Giving Advice with 'sollen'",
      "explanation": "Use 'sollen' to give advice or recommendations. Conjugation: ich soll, du sollst, er/sie/es soll, wir sollen, ihr sollt, sie/Sie sollen. The main verb goes at the end.",
      "examples": [
        "Du sollst mehr Wasser trinken.",
        "Er soll weniger Zucker essen.",
        "Wir sollen regelmÃ¤ÃŸig Sport machen.",
        "Sie sollen frÃ¼her schlafen."
      ]
    },
    {
      "topic": "Imperative for Health Advice",
      "explanation": "Use the imperative to give direct advice. 'du'-form: verb stem (+ e). 'ihr'-form: verb stem + t. 'Sie'-form: verb + Sie.",
      "examples": [
        "Trink mehr Wasser! (du)",
        "Esst mehr GemÃ¼se! (ihr)",
        "Schlafen Sie acht Stunden! (Sie)",
        "HÃ¶r auf zu rauchen! (du)"
      ]
    }
  ],
