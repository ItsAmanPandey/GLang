{
  "id": "A1_GF4",
  "level": "A1",
  "type": "grammarFocus",
  "number": "GF4",
  "title": "Perfekt mit haben",
  "subtitle": "Conversational past with haben as auxiliary",
  "focus": ["Perfekt", "Past Participle", "haben"],
  "conceptSections": [
    {
      "id": "gf4-concept-1",
      "heading": "When to use Perfekt",
      "explanation": "In spoken German, the Perfekt tense is used to talk about past events. Written German often uses the Präteritum (simple past), but in everyday conversation, Perfekt dominates. Compare: Written: 'Ich kaufte ein Buch.' vs Spoken: 'Ich habe ein Buch gekauft.'",
      "examples": [
        { "de": "Gestern habe ich lange geschlafen.", "en": "Yesterday I slept a long time.", "note": "Perfekt for spoken past" },
        { "de": "Was hast du am Wochenende gemacht?", "en": "What did you do at the weekend?", "note": "Common question in Perfekt" }
      ]
    },
    {
      "id": "gf4-concept-2",
      "heading": "Formation: haben + past participle",
      "explanation": "Perfekt = conjugated 'haben' in position 2 + past participle at the end. This creates the Satzklammer (sentence bracket).",
      "table": {
        "headers": ["Pronoun", "haben (conjugated)"],
        "rows": [
          ["ich", "habe"],
          ["du", "hast"],
          ["er/es/sie", "hat"],
          ["wir", "haben"],
          ["ihr", "habt"],
          ["sie/Sie", "haben"]
        ]
      },
      "examples": [
        { "de": "Ich habe einen Brief geschrieben.", "en": "I wrote a letter.", "note": "haben in pos.2, geschrieben at end" },
        { "de": "Hast du das Buch gelesen?", "en": "Did you read the book?", "note": "Question: haben first" }
      ]
    },
    {
      "id": "gf4-concept-3",
      "heading": "Weak (regular) past participles",
      "explanation": "Regular verbs form their past participle with ge- + verb stem + -t. These are called 'weak' verbs because the stem does not change.",
      "table": {
        "headers": ["Infinitive", "Past Participle", "English"],
        "rows": [
          ["machen", "gemacht", "done/made"],
          ["kaufen", "gekauft", "bought"],
          ["lernen", "gelernt", "learned"],
          ["spielen", "gespielt", "played"],
          ["kochen", "gekocht", "cooked"],
          ["hören", "gehört", "heard"],
          ["fragen", "gefragt", "asked"],
          ["sagen", "gesagt", "said"],
          ["arbeiten", "gearbeitet", "worked"],
          ["warten", "gewartet", "waited"]
        ]
      },
      "examples": [
        { "de": "Ich habe Deutsch gelernt.", "en": "I learned German.", "note": "lernen → gelernt" },
        { "de": "Sie hat Suppe gekocht.", "en": "She cooked soup.", "note": "kochen → gekocht" }
      ]
    },
    {
      "id": "gf4-concept-4",
      "heading": "Strong (irregular) past participles",
      "explanation": "Irregular verbs change their stem in the past participle and end in -en. These must be memorised individually.",
      "table": {
        "headers": ["Infinitive", "Past Participle", "English"],
        "rows": [
          ["schreiben", "geschrieben", "written"],
          ["lesen", "gelesen", "read"],
          ["sehen", "gesehen", "seen"],
          ["essen", "gegessen", "eaten"],
          ["trinken", "getrunken", "drunk"],
          ["nehmen", "genommen", "taken"],
          ["sprechen", "gesprochen", "spoken"],
          ["finden", "gefunden", "found"],
          ["geben", "gegeben", "given"],
          ["helfen", "geholfen", "helped"]
        ]
      },
      "examples": [
        { "de": "Ich habe das Buch gelesen.", "en": "I read the book.", "note": "lesen → gelesen" },
        { "de": "Er hat Pizza gegessen.", "en": "He ate pizza.", "note": "essen → gegessen" }
      ]
    },
    {
      "id": "gf4-concept-5",
      "heading": "Satzklammer in Perfekt",
      "explanation": "The Satzklammer (sentence bracket) places the conjugated verb (haben) in position 2 and the past participle at the final position. Everything else goes in between.",
      "examples": [
        { "de": "Ich | habe | gestern im Park | gespielt.", "en": "I played in the park yesterday.", "note": "habe = pos.2, gespielt = end" },
        { "de": "Wir | haben | den ganzen Tag | gearbeitet.", "en": "We worked the whole day.", "note": "haben = pos.2, gearbeitet = end" }
      ]
    }
  ],
