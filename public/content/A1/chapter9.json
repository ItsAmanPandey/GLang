  "grammar": [
    {
      "topic": "Prepositions of place",
      "explanation": "In German, prepositions like 'in' (in), 'auf' (on), and 'unter' (under) answer the question 'Wo?' (Where?). E.g. 'Das Buch liegt auf dem Tisch.' (The book lies on the table).",
      "examples": [
        "Das Buch liegt auf dem Tisch.",
        "Die Lampe steht auf dem Schreibtisch.",
        "Der Teppich liegt auf dem Boden.",
        "Das Bild hängt an der Wand."
      ]
    },
    {
      "topic": "Stehen vs. Liegen",
      "explanation": "'Stehen' is used for objects that are standing upright (like a cabinet or a fridge). 'Liegen' is used for objects that are lying flat (like a rug or a book on a bed).",
      "examples": [
        "Ich lege das Buch auf den Tisch.",
        "Er stellt die Vase auf den Schrank.",
        "Sie hängt das Bild an die Wand.",
        "Wir legen den Teppich auf den Boden."
      ]
    }
  ],
