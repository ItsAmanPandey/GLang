  "grammar": [
    {
      "topic": "Reflexive Verbs",
      "explanation": "Some German verbs are reflexive and need a reflexive pronoun: mich, dich, sich, uns, euch, sich. E.g. 'Ich freue mich' (I am happy). The pronoun changes based on the subject.",
      "examples": [
        "Ich freue mich auf die Party.",
        "Er verkleidet sich als Pirat.",
        "Wir freuen uns auf Weihnachten.",
        "Freust du dich?"
      ]
    },
    {
      "topic": "Separable Verbs in Context",
      "explanation": "Verbs like einladen, mitbringen, aufräumen, anstoßen, and vorbereiten are separable. In the present tense, the prefix goes to the end.",
      "examples": [
        "Ich lade dich zur Party ein.",
        "Bringst du einen Kuchen mit?",
        "Wir stoßen um Mitternacht an.",
        "Sie räumt nach der Party auf."
      ]
    }
  ],
