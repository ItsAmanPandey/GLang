  "grammar": [
    {
      "topic": "Review: Present Tense",
      "explanation": "Regular verbs: remove -en from the infinitive, add endings: -e, -st, -t, -en, -t, -en. Irregular verbs change their stem vowel in du/er forms (e.g. sprechenﾃ｢窶窶冱prichst, lesenﾃ｢窶窶冤iest).",
      "examples": [
        "Ich lerne Deutsch.",
        "Du sprichst gut.",
        "Er liest ein Buch.",
        "Wir machen ﾃη澱ungen."
      ]
    },
    {
      "topic": "Review: Perfekt (Past Tense)",
      "explanation": "Haben/sein + Partizip II at the end. Regular: ge- + stem + -t (gemacht). Irregular: ge- + stem + -en (gegessen). Motion/change verbs use sein.",
      "examples": [
        "Ich habe Deutsch gelernt.",
        "Er ist nach Berlin gefahren.",
        "Wir haben viel geﾃδｼbt.",
        "Sie hat die Prﾃδｼfung bestanden."
      ]
    },
    {
      "topic": "Review: Modal Verbs",
      "explanation": "kﾃδｶnnen (can), mﾃδｼssen (must), wollen (want), sollen (should), dﾃδｼrfen (may), mﾃδｶchten (would like). The main verb goes at the end in infinitive form.",
      "examples": [
        "Ich kann Deutsch sprechen.",
        "Du musst mehr ﾃδｼben.",
        "Er will die Prﾃδｼfung bestehen.",
        "Wir sollen den Text wiederholen."
      ]
    }
  ],
