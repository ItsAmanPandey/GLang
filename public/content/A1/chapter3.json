  "grammar": [
    {
      "topic": "Indefinite Articles: ein / eine",
      "explanation": "Use 'ein' for masculine and neuter nouns (ein Apfel, ein Brot). Use 'eine' for feminine nouns (eine Banane).",
      "examples": [
        "Das ist ein Apfel.",
        "Ich brauche eine Tomate."
      ]
    },
    {
      "topic": "Negative Articles: kein / keine",
      "explanation": "To say 'not a' or 'no' with nouns, add a 'k' to the indefinite article. Use 'kein' for masculine/neuter, 'keine' for feminine/plural.",
      "examples": [
        "Das ist kein Apfel.",
        "Ich habe keine Bananen."
      ]
    },
    {
      "topic": "The verb 'essen' (to eat)",
      "explanation": "'Essen' is irregular in the du and er/sie/es forms: ich esse, du isst, er/sie/es isst, wir essen, ihr esst, Sie/sie essen.",
      "examples": [
        "Ich esse gern Käse.",
        "Isst du Fleisch?"
      ]
    },
    {
      "topic": "The verb 'möchten' (would like)",
      "explanation": "Used for polite requests, especially in restaurants/shops: ich möchte, du möchtest, er/sie möchte, wir möchten, ihr möchtet, Sie/sie möchten.",
      "examples": [
        "Ich möchte einen Kaffee, bitte.",
        "Was möchten Sie trinken?"
      ]
    }
  ],
