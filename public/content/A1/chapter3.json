{
  "id": "A1_03",
  "level": "A1",
  "number": 3,
  "title": "Essen und Trinken",
  "subtitle": "Food, Groceries, and Prices",
  "focus": [
    "Naming foods and drinks",
    "Expressing likes and dislikes (gern / nicht gern)",
    "Shopping and prices",
    "Indefinite articles (ein, eine) and negative articles (kein, keine)"
  ],
  "tips": [
    {
      "title": "Gern essen",
      "body": "To say you like doing something, use 'gern' after the verb. Example: Ich esse gern Pizza (I like eating pizza)."
    },
    {
      "title": "Kein vs. Nicht",
      "body": "Use 'kein' to negate nouns with indefinite articles (Ich habe keinen Hunger). Use 'nicht' to negate verbs and adjectives (Das Essen ist nicht gut)."
    },
    {
      "title": "Prices in German",
      "body": "A price like 2,50 € is spoken as 'zwei Euro fünfzig'."
    }
  ],
