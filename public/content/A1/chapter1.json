  "grammar": [
    {
      "topic": "The verb 'sein' (to be)",
      "explanation": "The verb 'sein' is irregular. Memorize these forms first: ich bin (I am), du bist (you are), er/sie/es ist (he/she/it is), Sie sind (you are - formal).",
      "examples": [
        "Ich bin glücklich.",
        "Bist du neu hier?",
        "Sie ist aus Frankreich.",
        "Sind Sie Herr Müller?"
      ]
    },
    {
      "topic": "The verb 'heißen' (to be called)",
      "explanation": "A regular verb with a slight spelling change for 'du': ich heiße, du heißt, er/sie heißt, Sie heißen.",
      "examples": [
        "Ich heiße Clara.",
        "Wie heißt du?",
        "Er heißt Max."
      ]
    },
    {
      "topic": "The verb 'kommen' (to come)",
      "explanation": "A completely regular verb: ich komme, du kommst, er/sie kommt, Sie kommen.",
      "examples": [
        "Ich komme aus Italien.",
        "Woher kommst du?"
      ]
    },
    {
      "topic": "W-Questions",
      "explanation": "Questions that ask for information start with a W-word. The verb is always in the second position.",
      "examples": [
        "Wie heißt du?",
        "Wer ist das?",
        "Woher kommen Sie?"
      ]
    }
  ],
