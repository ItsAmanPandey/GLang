  "title": "Erste Kontakte",
  "subtitle": "Greetings, Introductions, and Origins",
  "focus": [
    "Saying hello and goodbye",
    "Introducing yourself and others",
    "Asking for names and origins",
    "Formal vs. Informal address (Sie vs. du)"
  ],
  "tips": [
    {
      "title": "The verb comes second",
      "body": "In a standard German sentence, the conjugated verb is always in the second position. Example: 'Ich **komme** aus Berlin.'"
    },
    {
      "title": "Capitalizing Nouns",
      "body": "In German, all nouns are capitalized, no matter where they appear in a sentence. (e.g., der Name, das Land)."
    },
    {
      "title": "Formal and Informal",
      "body": "Use 'du' for friends, family, and children. Use 'Sie' for strangers, adults in formal settings, and authority figures."
    }
  ],
