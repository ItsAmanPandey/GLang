  "grammar": [
    {
      "topic": "Comparatives",
      "explanation": "Add '-er' to the adjective stem. Many short adjectives get an umlaut (groß→größer, alt→älter). Use 'als' for 'than'. E.g. 'Berlin ist größer als München'.",
      "examples": [
        "Das Hotel ist teurer als die Pension.",
        "Der Sommer ist wärmer als der Frühling.",
        "Mein Koffer ist schwerer als deiner.",
        "Dieses Zimmer ist schöner als das andere."
      ]
    },
    {
      "topic": "Superlatives",
      "explanation": "Use 'am + adjective + sten' or 'der/die/das + adjective + ste'. Short adjectives often get an umlaut. E.g. 'am größten', 'der schönste'.",
      "examples": [
        "Das ist das schönste Hotel.",
        "Am liebsten fahre ich nach Italien.",
        "Der Rhein ist der längste Fluss.",
        "Das war der beste Urlaub."
      ]
    }
  ],
