{
  "id": "A1_04",
  "level": "A1",
  "number": 4,
  "title": "Mein Tag",
  "subtitle": "Time, Daily Routine, and Separable Verbs",
  "focus": [
    "Asking and telling the time",
    "Days of the week and times of day",
    "Talking about your daily routine",
    "Using separable verbs (trennbare Verben)"
  ],
  "tips": [
    {
      "title": "Separable Verbs split up",
      "body": "When using a separable verb like 'aufstehen' (to wake up) in a normal sentence, the prefix goes to the very end. Example: Ich stehe um 7 Uhr auf."
    },
    {
      "title": "Time prepositions",
      "body": "Use 'um' for exact times (um acht Uhr). Use 'am' for days of the week and parts of the day (am Montag, am Morgen)."
    },
    {
      "title": "Invert the subject and verb",
      "body": "If you start a sentence with time, the verb MUST stay in the second position. Example: 'Am Montag gehe ich zur Arbeit.' (NOT: Am Montag ich gehe...)"
    }
  ],
