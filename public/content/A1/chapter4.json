  "grammar": [
    {
      "topic": "Telling Time",
      "explanation": "To ask the time: 'Wie spät ist es?' or 'Wie viel Uhr ist es?'. To answer: 'Es ist...'. Use 'vor' (to) and 'nach' (past). 'Halb' always looks to the next hour (halb acht = 7:30).",
      "examples": [
        "Es ist zehn Uhr.",
        "Es ist Viertel nach drei (3:15).",
        "Es ist halb fünf (4:30)."
      ]
    },
    {
      "topic": "Separable Verbs (Trennbare Verben)",
      "explanation": "Some verbs have a prefix (auf, ein, an, fern). The prefix separates from the verb and goes to the END of the sentence.",
      "examples": [
        "aufstehen -> Ich stehe früh auf.",
        "einkaufen -> Wir kaufen im Supermarkt ein.",
        "anfangen -> Wann fängt der Film an?"
      ]
    },
    {
      "topic": "Time prepositions",
      "explanation": "Use 'um' for exact clock times. Use 'am' for days and parts of the day (except 'in der Nacht').",
      "examples": [
        "um 8 Uhr",
        "am Montag",
        "am Vormittag",
        "in der Nacht"
      ]
    }
  ],
