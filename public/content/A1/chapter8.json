  "grammar": [
    {
      "topic": "Expressing pain with 'wehtun'",
      "explanation": "To say something hurts, use 'tun ... weh'. E.g. 'Mein Kopf tut weh' (My head hurts). For plural parts: 'Meine Ohren tun weh' (My ears hurt).",
      "examples": [
        "Mein Kopf tut weh.",
        "Der Bauch tut mir weh.",
        "Tut dein Arm weh?",
        "Meine Beine tun weh."
      ]
    },
    {
      "topic": "Expressing pain with 'Schmerzen haben'",
      "explanation": "Another way to express pain is using 'haben' + Schmerzen. E.g. 'Ich habe Bauchschmerzen' (I have a stomach ache).",
      "examples": [
        "Du sollst zum Arzt gehen.",
        "Sie soll mehr schlafen.",
        "Er soll Tabletten nehmen.",
        "Wir sollen viel Wasser trinken."
      ]
    }
  ],
