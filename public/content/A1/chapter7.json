  "grammar": [
    {
      "topic": "The verb 'gefallen'",
      "explanation": "The verb 'gefallen' means 'to be pleasing to'. The object being liked is the subject of the sentence, and the person who likes it is in the dative case. E.g. 'Das Hemd gefällt mir.' (I like the shirt / The shirt pleases me).",
      "examples": [
        "Das Kleid gefällt mir.",
        "Die Schuhe gefallen ihr nicht.",
        "Gefällt dir die Jacke?",
        "Der Mantel gefällt ihm."
      ]
    },
    {
      "topic": "The verb 'passen'",
      "explanation": "'Passen' means 'to fit'. Like 'gefallen', the person it fits takes the dative case. E.g. 'Die Hose passt mir.' (The pants fit me).",
      "examples": [
        "Die Hose passt nicht.",
        "Welche Größe brauchen Sie?",
        "Das T-Shirt ist zu klein.",
        "Haben Sie das in Größe M?"
      ]
    }
  ],
