{
  "id": "A1_GF2",
  "level": "A1",
  "type": "grammarFocus",
  "number": "GF2",
  "title": "Der Akkusativ",
  "subtitle": "Direct objects and article changes",
  "focus": [
    "Akkusativ",
    "Direct Objects",
    "Accusative Pronouns"
  ],
  "conceptSections": [
    {
      "id": "gf2-concept-1",
      "heading": "What the accusative marks",
      "explanation": "The accusative case marks the direct object — the thing being acted upon. Compare: 'Das ist ein Hund.' (nominative — the dog IS something) vs 'Ich sehe einen Hund.' (accusative — the dog is being SEEN). Notice: only the masculine article changes. Neuter, feminine, and plural articles stay the same.",
      "examples": [
        {
          "de": "Das ist ein Hund.",
          "en": "That is a dog. (Nominativ)",
          "note": "subject — no change"
        },
        {
          "de": "Ich sehe einen Hund.",
          "en": "I see a dog. (Akkusativ)",
          "note": "direct object — ein → einen"
        }
      ]
    },
    {
      "id": "gf2-concept-2",
      "heading": "Accusative article changes",
      "explanation": "Only masculine articles change in the accusative. Feminine, neuter, and plural forms remain identical to the nominative. This is the most important rule to memorise at A1 level.",
      "table": {
        "headers": [
          "Gender",
          "Definit (Nom → Akk)",
          "Indefinit (Nom → Akk)",
          "Negativ (Nom → Akk)"
        ],
        "rows": [
          [
            "Masculine",
            "der → den",
            "ein → einen",
            "kein → keinen"
          ],
          [
            "Neuter",
            "das → das",
            "ein → ein",
            "kein → kein"
          ],
          [
            "Feminine",
            "die → die",
            "eine → eine",
            "keine → keine"
          ],
          [
            "Plural",
            "die → die",
            "— → —",
            "keine → keine"
          ]
        ]
      },
      "examples": [
        {
          "de": "Ich kaufe den Kuchen.",
          "en": "I buy the cake.",
          "note": "masc: der → den"
        },
        {
          "de": "Sie trinkt das Wasser.",
          "en": "She drinks the water.",
          "note": "neuter: das stays das"
        },
        {
          "de": "Wir lesen die Zeitung.",
          "en": "We read the newspaper.",
          "note": "fem: die stays die"
        }
      ]
    },
    {
      "id": "gf2-concept-3",
      "heading": "Accusative personal pronouns",
      "explanation": "When the direct object is a pronoun, use the accusative pronoun forms. Compare them side by side with the nominative to see the pattern.",
      "table": {
        "headers": [
          "Nominativ",
          "Akkusativ",
          "English"
        ],
        "rows": [
          [
            "ich",
            "mich",
            "me"
          ],
          [
            "du",
            "dich",
            "you (informal)"
          ],
          [
            "er",
            "ihn",
            "him"
          ],
          [
            "es",
            "es",
            "it"
          ],
          [
            "sie",
            "sie",
            "her"
          ],
          [
            "wir",
            "uns",
            "us"
          ],
          [
            "ihr",
            "euch",
            "you (plural)"
          ],
          [
            "sie/Sie",
            "sie/Sie",
            "them / you (formal)"
          ]
        ]
      },
      "examples": [
        {
          "de": "Siehst du mich?",
          "en": "Do you see me?",
          "note": "ich → mich"
        },
        {
          "de": "Ich kenne ihn gut.",
          "en": "I know him well.",
          "note": "er → ihn"
        },
        {
          "de": "Wir besuchen euch morgen.",
          "en": "We visit you tomorrow.",
          "note": "ihr → euch"
        }
      ]
    },
    {
      "id": "gf2-concept-4",
      "heading": "Common verbs with accusative objects",
      "explanation": "These A1-level verbs frequently take a direct object in the accusative case. Learn them with example sentences to build natural patterns.",
      "examples": [
        {
          "de": "Ich kaufe einen Apfel.",
          "en": "I buy an apple.",
          "note": "kaufen = to buy"
        },
        {
          "de": "Hast du einen Hund?",
          "en": "Do you have a dog?",
          "note": "haben = to have"
        },
        {
          "de": "Wir brauchen ein neues Auto.",
          "en": "We need a new car.",
          "note": "brauchen = to need"
        },
        {
          "de": "Nehmen Sie den Bus?",
          "en": "Do you take the bus?",
          "note": "nehmen = to take"
        },
        {
          "de": "Ich sehe den Berg.",
          "en": "I see the mountain.",
          "note": "sehen = to see"
        },
        {
          "de": "Findest du den Schlüssel?",
          "en": "Do you find the key?",
          "note": "finden = to find"
        },
        {
          "de": "Was machst du?",
          "en": "What are you doing?",
          "note": "machen = to do/make"
        },
        {
          "de": "Sie isst einen Salat.",
          "en": "She eats a salad.",
          "note": "essen = to eat"
        },
        {
          "de": "Er trinkt einen Kaffee.",
          "en": "He drinks a coffee.",
          "note": "trinken = to drink"
        }
      ]
    }
  ],
