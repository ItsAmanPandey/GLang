  "grammar": [
    {
      "topic": "Prepositions with Accusative (Movement)",
      "explanation": "When indicating movement to a place (where to?), two-way prepositions take the Accusative case (den, die, das, die). E.g. 'Ich stelle die Lampe auf den Tisch' (I place the lamp onto the table).",
      "examples": [
        "Ich stelle die Lampe auf den Tisch.",
        "Er legt das Buch auf das Regal.",
        "Sie hÃ¤ngt das Bild an die Wand.",
        "Wir stellen den Schrank in die Ecke."
      ]
    },
    {
      "topic": "Ordinal Numbers for Floors",
      "explanation": "To say which floor you live on, use 'im' + ordinal number. 'im ersten Stock' (on the first floor), 'im zweiten Stock' (on the second floor).",
      "examples": [
        "Ich wohne im ersten Stock.",
        "Das BÃ¼ro ist im zweiten Stock.",
        "Die Wohnung im dritten Stock ist frei.",
        "Der Aufzug fÃ¤hrt bis zum vierten Stock."
      ]
    }
  ],
