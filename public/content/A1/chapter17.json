  "grammar": [
    {
      "topic": "Expressing Opinions",
      "explanation": "To express your opinion in German, use phrases like 'Ich finde, dass...', 'Ich denke, dass...', 'Ich glaube, dass...', or 'Meiner Meinung nach...'. With 'dass', the verb goes to the end of the clause.",
      "examples": [
        "Ich finde, dass das Internet nützlich ist.",
        "Ich denke, dass Handys wichtig sind.",
        "Meiner Meinung nach ist das Buch gut.",
        "Ich glaube, dass er recht hat."
      ]
    },
    {
      "topic": "More Separable Verbs",
      "explanation": "Verbs like anrufen, fernsehen, herunterladen, and hochladen are separable. In the present tense, the prefix goes to the end. In the Perfekt, 'ge-' goes between the prefix and the stem.",
      "examples": [
        "Ich rufe dich morgen an.",
        "Abends sehe ich oft fern.",
        "Ich habe die App heruntergeladen.",
        "Er hat ein Foto hochgeladen."
      ]
    }
  ],
