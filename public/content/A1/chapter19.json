  "grammar": [
    {
      "topic": "The Verb 'm횄쩌ssen' (must/have to)",
      "explanation": "The modal verb 'm횄쩌ssen' expresses necessity or obligation. Conjugation: ich muss, du musst, er/sie/es muss, wir m횄쩌ssen, ihr m횄쩌sst, sie/Sie m횄쩌ssen. The main verb goes to the end in infinitive form.",
      "examples": [
        "Wir m횄쩌ssen die Umwelt sch횄쩌tzen.",
        "Du musst mehr Wasser trinken.",
        "Ich muss den M횄쩌ll trennen.",
        "Sie m횄쩌ssen p횄쩌nktlich sein."
      ]
    },
    {
      "topic": "Compound Nouns",
      "explanation": "German loves compound nouns! Two or more nouns join to form one word. The last noun determines the article and gender. E.g. der Regen + der Bogen = der Regenbogen.",
      "examples": [
        "der Weihnachtsbaum = Weihnachten + Baum",
        "die Landschaft = das Land + die Schaft",
        "das Schwimmbad = schwimmen + das Bad",
        "der Regenbogen = der Regen + der Bogen"
      ]
    }
  ],
