  "grammar": [
    {
      "topic": "Prepositions of Time: am, im, um",
      "explanation": "Use 'am' (an dem) for days and parts of the day (am Montag, am Morgen). Use 'im' (in dem) for months and seasons (im Januar, im Sommer). Use 'um' for specific clock times (um 8 Uhr).",
      "examples": [
        "Am Montag gehe ich arbeiten.",
        "Am Morgen trinke ich Kaffee.",
        "Im Januar ist es kalt.",
        "Um 8 Uhr beginnt der Kurs."
      ]
    },
    {
      "topic": "Ordinal Numbers for Dates",
      "explanation": "When expressing the date, you use ordinal numbers. In German, they usually end in '-te' (1st-19th) or '-ste' (20+). When used with 'am', they add an '-n' (e.g. 'am ersten', 'am siebten').",
      "examples": [
        "Heute ist der erste Mai.",
        "Am dritten Oktober ist ein Feiertag.",
        "Mein Geburtstag ist am siebten Juni.",
        "Der zwanzigste Dezember ist bald."
      ]
    }
  ],
