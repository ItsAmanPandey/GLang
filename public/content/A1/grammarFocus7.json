{
  "id": "A1_GF7",
  "level": "A1",
  "type": "grammarFocus",
  "number": "GF7",
  "title": "Modalverben",
  "subtitle": "The six modal verbs and Satzklammer",
  "focus": ["Modal Verbs", "Satzklammer", "Conjugation"],
  "conceptSections": [
    {
      "id": "gf7-concept-1",
      "heading": "What modal verbs do",
      "explanation": "Modal verbs modify the meaning of a main verb. The modal is conjugated and sits in position 2, while the main verb stays as an infinitive at the end of the sentence. This creates the Satzklammer (sentence bracket).",
      "examples": [
        { "de": "Ich kann Deutsch sprechen.", "en": "I can speak German.", "note": "kann = pos.2, sprechen = end" },
        { "de": "Du musst die Hausaufgabe machen.", "en": "You must do the homework.", "note": "musst = pos.2, machen = end" }
      ]
    },
    {
      "id": "gf7-concept-2",
      "heading": "Meaning overview",
      "explanation": "Each modal verb expresses a different attitude toward the action: ability, obligation, desire, permission, instruction, or preference.",
      "table": {
        "headers": ["Modal", "Meaning", "Example"],
        "rows": [
          ["können", "ability / possibility", "Ich kann schwimmen."],
          ["müssen", "obligation / necessity", "Ich muss arbeiten."],
          ["wollen", "desire / intention", "Ich will nach Hause gehen."],
          ["dürfen", "permission", "Darf ich hier sitzen?"],
          ["sollen", "instruction / recommendation", "Du sollst mehr lernen."],
          ["mögen / möchten", "preference / wish", "Ich möchte einen Kaffee."]
        ]
      },
      "examples": []
    },
    {
      "id": "gf7-concept-3",
      "heading": "Conjugation table",
      "explanation": "All modal verbs are irregular in the ich and er/es/sie forms. Notice that ich and er/es/sie forms are identical for every modal.",
      "table": {
        "headers": ["Pronoun", "können", "müssen", "wollen", "dürfen", "sollen", "möchten"],
        "rows": [
          ["ich", "kann", "muss", "will", "darf", "soll", "möchte"],
          ["du", "kannst", "musst", "willst", "darfst", "sollst", "möchtest"],
          ["er/es/sie", "kann", "muss", "will", "darf", "soll", "möchte"],
          ["wir", "können", "müssen", "wollen", "dürfen", "sollen", "möchten"],
          ["ihr", "könnt", "müsst", "wollt", "dürft", "sollt", "möchtet"],
          ["sie/Sie", "können", "müssen", "wollen", "dürfen", "sollen", "möchten"]
        ]
      },
      "examples": []
    },
    {
      "id": "gf7-concept-4",
      "heading": "möchten vs mögen",
      "explanation": "'möchten' (would like to) expresses a polite wish or request. 'mögen' (to like) expresses a general preference. At A1 level, möchten is far more common.",
      "examples": [
        { "de": "Ich möchte einen Tee bestellen.", "en": "I would like to order a tea.", "note": "möchten = polite wish" },
        { "de": "Ich mag Schokolade.", "en": "I like chocolate.", "note": "mögen = general preference" }
      ]
    },
    {
      "id": "gf7-concept-5",
      "heading": "Satzklammer with modals",
      "explanation": "The conjugated modal sits in position 2. The infinitive of the main verb goes to the very end. Subject, objects, and adverbs sit in between.",
      "examples": [
        { "de": "Ich | kann | morgen nicht | kommen.", "en": "I cannot come tomorrow.", "note": "kann=pos.2, kommen=end" },
        { "de": "Wir | müssen | jeden Tag Deutsch | lernen.", "en": "We must learn German every day.", "note": "müssen=pos.2, lernen=end" }
      ]
    },
    {
      "id": "gf7-concept-6",
      "heading": "Negation with modals",
      "explanation": "To negate a modal sentence, place 'nicht' before the infinitive at the end.",
      "examples": [
        { "de": "Ich kann heute nicht kommen.", "en": "I cannot come today.", "note": "nicht before kommen" },
        { "de": "Du darfst hier nicht rauchen.", "en": "You may not smoke here.", "note": "nicht before rauchen" }
      ]
    }
  ],
