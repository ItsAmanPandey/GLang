{
  "id": "A1_GF8",
  "level": "A1",
  "type": "grammarFocus",
  "number": "GF8",
  "title": "Konjunktiv II mit würde",
  "subtitle": "Wishes, hypotheticals, and polite requests",
  "focus": ["Konjunktiv II", "würde + Infinitiv", "wäre / hätte"],
  "conceptSections": [
    {
      "id": "gf8-concept-1",
      "heading": "When to use Konjunktiv II",
      "explanation": "Konjunktiv II is used for hypothetical situations, polite requests, and wishes that are unlikely or not yet real. Compare present tense (real) with Konjunktiv II (hypothetical).",
      "examples": [
        { "de": "Ich fahre nach Berlin.", "en": "I am going to Berlin. (real)", "note": "Present tense — happening" },
        { "de": "Ich würde gern nach Berlin fahren.", "en": "I would like to go to Berlin. (wish)", "note": "Konjunktiv II — hypothetical" }
      ]
    },
    {
      "id": "gf8-concept-2",
      "heading": "Conjugation of würde",
      "explanation": "The form 'würde' + infinitive is the standard way to express Konjunktiv II for most verbs at A1 level. The infinitive goes to the end, just like with modal verbs.",
      "table": {
        "headers": ["Pronoun", "würde"],
        "rows": [
          ["ich", "würde"],
          ["du", "würdest"],
          ["er/es/sie", "würde"],
          ["wir", "würden"],
          ["ihr", "würdet"],
          ["sie/Sie", "würden"]
        ]
      },
      "examples": [
        { "de": "Ich würde gern Deutsch lernen.", "en": "I would like to learn German.", "note": "würde + infinitive" },
        { "de": "Würdest du mir helfen?", "en": "Would you help me?", "note": "polite request" }
      ]
    },
    {
      "id": "gf8-concept-3",
      "heading": "Common usage patterns",
      "explanation": "The most frequent Konjunktiv II patterns at A1 level include wishes with 'gern', preferences with 'lieber', and polite requests with 'Würden Sie bitte...'.",
      "examples": [
        { "de": "Ich würde gern Pizza essen.", "en": "I would like to eat pizza.", "note": "gern = gladly (wish)" },
        { "de": "Ich würde lieber zu Hause bleiben.", "en": "I would rather stay at home.", "note": "lieber = rather (preference)" },
        { "de": "Würden Sie bitte das Fenster schließen?", "en": "Would you please close the window?", "note": "polite formal request" }
      ]
    },
    {
      "id": "gf8-concept-4",
      "heading": "wäre and hätte — special Konjunktiv II forms",
      "explanation": "The verbs 'sein' and 'haben' have their own Konjunktiv II forms that are used instead of 'würde sein' and 'würde haben'. These are very common and must be memorised.",
      "table": {
        "headers": ["Pronoun", "wäre (sein)", "hätte (haben)"],
        "rows": [
          ["ich", "wäre", "hätte"],
          ["du", "wärst", "hättest"],
          ["er/es/sie", "wäre", "hätte"],
          ["wir", "wären", "hätten"],
          ["ihr", "wärt", "hättet"],
          ["sie/Sie", "wären", "hätten"]
        ]
      },
      "examples": [
        { "de": "Ich wäre gern in Italien.", "en": "I would like to be in Italy.", "note": "wäre = would be" },
        { "de": "Hätten Sie einen Moment Zeit?", "en": "Would you have a moment?", "note": "hätte = would have" }
      ]
    },
    {
      "id": "gf8-concept-5",
      "heading": "Useful vocabulary for wishes",
      "explanation": "These words often appear with Konjunktiv II to express wishes and preferences.",
      "examples": [
        { "de": "Ich würde unbedingt nach Japan reisen.", "en": "I would definitely travel to Japan.", "note": "unbedingt = definitely" },
        { "de": "Vielleicht würde ich Medizin studieren.", "en": "Maybe I would study medicine.", "note": "vielleicht = maybe" },
        { "de": "Eigentlich würde ich lieber lesen.", "en": "Actually I would rather read.", "note": "eigentlich = actually" },
        { "de": "Ich würde auf jeden Fall kommen.", "en": "I would definitely come.", "note": "auf jeden Fall = in any case" },
        { "de": "Am liebsten würde ich schlafen.", "en": "Most of all I would like to sleep.", "note": "am liebsten = most of all" }
      ]
    }
  ],
