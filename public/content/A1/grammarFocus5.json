{
  "id": "A1_GF5",
  "level": "A1",
  "type": "grammarFocus",
  "number": "GF5",
  "title": "Perfekt mit sein",
  "subtitle": "Motion and change-of-state verbs with sein",
  "focus": ["Perfekt mit sein", "Movement Verbs", "Präteritum war/hatte"],
  "conceptSections": [
    {
      "id": "gf5-concept-1",
      "heading": "Which verbs take sein?",
      "explanation": "Some verbs use 'sein' instead of 'haben' as the auxiliary in Perfekt. These fall into two categories: verbs of physical movement from point A to point B (gehen, fahren, kommen, fliegen, laufen, reisen, schwimmen), and verbs expressing a change of state (aufwachen, einschlafen, werden, passieren, sterben).",
      "examples": [
        { "de": "Ich bin nach Berlin gefahren.", "en": "I drove/went to Berlin.", "note": "fahren = movement A→B → sein" },
        { "de": "Er ist gestern angekommen.", "en": "He arrived yesterday.", "note": "ankommen = movement → sein" },
        { "de": "Sie ist eingeschlafen.", "en": "She fell asleep.", "note": "einschlafen = change of state → sein" },
        { "de": "Das Kind ist schnell gewachsen.", "en": "The child grew quickly.", "note": "wachsen = change of state → sein" }
      ]
    },
    {
      "id": "gf5-concept-2",
      "heading": "sein conjugation in Perfekt",
      "explanation": "When using sein as the auxiliary, conjugate it the same way as in present tense. The past participle still goes to the end.",
      "table": {
        "headers": ["Pronoun", "sein (conjugated)"],
        "rows": [
          ["ich", "bin"],
          ["du", "bist"],
          ["er/es/sie", "ist"],
          ["wir", "sind"],
          ["ihr", "seid"],
          ["sie/Sie", "sind"]
        ]
      },
      "examples": [
        { "de": "Ich bin nach Hause gegangen.", "en": "I went home.", "note": "gehen → gegangen, with sein" },
        { "de": "Wir sind in die Stadt gefahren.", "en": "We drove into town.", "note": "fahren → gefahren, with sein" }
      ]
    },
    {
      "id": "gf5-concept-3",
      "heading": "Präteritum of sein and haben",
      "explanation": "The verbs 'sein' and 'haben' are special: they commonly appear in Präteritum (simple past) even in spoken German, unlike other verbs. Learn these two sets of forms alongside Perfekt.",
      "table": {
        "headers": ["Pronoun", "sein → war", "haben → hatte"],
        "rows": [
          ["ich", "war", "hatte"],
          ["du", "warst", "hattest"],
          ["er/es/sie", "war", "hatte"],
          ["wir", "waren", "hatten"],
          ["ihr", "wart", "hattet"],
          ["sie/Sie", "waren", "hatten"]
        ]
      },
      "examples": [
        { "de": "Gestern war ich in Berlin.", "en": "Yesterday I was in Berlin.", "note": "war = Präteritum of sein" },
        { "de": "Gestern bin ich nach Berlin gefahren.", "en": "Yesterday I went to Berlin.", "note": "Perfekt with sein for the journey" },
        { "de": "Ich hatte keine Zeit.", "en": "I had no time.", "note": "hatte = Präteritum of haben" }
      ]
    },
    {
      "id": "gf5-concept-4",
      "heading": "haben vs sein comparison",
      "explanation": "Here is a side-by-side comparison showing which common verbs take haben and which take sein.",
      "table": {
        "headers": ["haben verbs", "Example", "sein verbs", "Example"],
        "rows": [
          ["machen", "Ich habe es gemacht.", "gehen", "Ich bin gegangen."],
          ["kaufen", "Sie hat Obst gekauft.", "kommen", "Er ist gekommen."],
          ["lernen", "Wir haben gelernt.", "fahren", "Wir sind gefahren."],
          ["essen", "Er hat Pizza gegessen.", "fliegen", "Sie ist geflogen."],
          ["trinken", "Ich habe Tee getrunken.", "laufen", "Er ist gelaufen."],
          ["lesen", "Sie hat gelesen.", "reisen", "Wir sind gereist."],
          ["schreiben", "Ich habe geschrieben.", "schwimmen", "Sie ist geschwommen."],
          ["kochen", "Er hat gekocht.", "aufwachen", "Ich bin aufgewacht."]
        ]
      },
      "examples": []
    }
  ],
