  "grammar": [
    {
      "topic": "Prepositions with Dative",
      "explanation": "When indicating location (where something is), two-way prepositions take the Dative case (dem, der, dem, den). E.g. 'Die Post ist neben dem Bahnhof'.",
      "examples": [
        "Die Post ist neben dem Bahnhof.",
        "Das Café ist gegenüber der Kirche.",
        "Die Haltestelle ist vor dem Hotel.",
        "Mein Auto steht hinter dem Haus."
      ]
    },
    {
      "topic": "Separable Verbs for Transport",
      "explanation": "Verbs like einsteigen, aussteigen, and umsteigen are separable. The prefix goes to the end of the clause. E.g. 'Ich steige in den Bus ein'.",
      "examples": [
        "Ich steige in den Bus ein.",
        "Wir steigen am Hauptbahnhof um.",
        "Sie steigt an der nächsten Haltestelle aus.",
        "Steig bitte schnell ein!"
      ]
    }
  ],
