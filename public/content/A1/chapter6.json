  "grammar": [
    {
      "topic": "Weather expressions",
      "explanation": "To describe the weather, German uses 'es ist' (it is) or specific verbs like 'es regnet' (it's raining) and 'es schneit' (it's snowing). E.g. 'Es ist kalt' (It is cold).",
      "examples": [
        "Es regnet heute.",
        "Der Himmel ist bewölkt.",
        "Im Sommer ist es heiß.",
        "Im Winter schneit es oft."
      ]
    },
    {
      "topic": "Seasons and 'im'",
      "explanation": "When talking about seasons, you always use the preposition 'im' (in dem). For example: 'im Sommer' (in the summer), 'im Winter' (in the winter).",
      "examples": [
        "Ich fahre nach Berlin.",
        "Wir fliegen nach Spanien.",
        "Er reist mit dem Zug.",
        "Sie fährt mit dem Auto."
      ]
    }
  ],
