{
  "id": "A1_GF1",
  "level": "A1",
  "type": "grammarFocus",
  "number": "GF1",
  "title": "Der Nominativ",
  "subtitle": "Subjects, articles, and personal pronouns",
  "focus": ["Nominativ", "Articles", "Personal Pronouns"],
  "conceptSections": [
    {
      "id": "gf1-concept-1",
      "heading": "What is the nominative case?",
      "explanation": "The nominative case marks the subject of a sentence — the person or thing performing the action. Every German sentence has a subject, and that subject is always in the nominative case. When you say 'Der Hund schläft', the dog (der Hund) is the subject — it is the one sleeping.",
      "table": {
        "headers": ["Gender", "Definite", "Indefinite", "Negative"],
        "rows": [
          ["Masculine", "der", "ein", "kein"],
          ["Neuter", "das", "ein", "kein"],
          ["Feminine", "die", "eine", "keine"],
          ["Plural", "die", "—", "keine"]
        ]
      },
      "examples": [
        { "de": "Der Tisch ist groß.", "en": "The table is big.", "note": "der = masculine nominative" },
        { "de": "Das Kind spielt draußen.", "en": "The child is playing outside.", "note": "das = neuter nominative" },
        { "de": "Die Lampe ist neu.", "en": "The lamp is new.", "note": "die = feminine nominative" },
        { "de": "Ein Mann wartet an der Tür.", "en": "A man is waiting at the door.", "note": "ein = masculine indefinite" },
        { "de": "Keine Katze sitzt auf dem Sofa.", "en": "No cat is sitting on the sofa.", "note": "keine = feminine negative" }
      ]
    },
    {
      "id": "gf1-concept-2",
      "heading": "Identifying the subject",
      "explanation": "To find the subject, ask 'Wer?' (Who?) or 'Was?' (What?) before the verb. The answer is the subject and takes the nominative case. In German, the subject can sometimes appear after the verb, especially after adverbs or in questions.",
      "examples": [
        { "de": "Die Lehrerin erklärt die Aufgabe.", "en": "The teacher explains the exercise.", "note": "Wer erklärt? → Die Lehrerin (subject)" },
        { "de": "Morgen kommt mein Bruder.", "en": "Tomorrow my brother is coming.", "note": "Wer kommt? → mein Bruder (subject after verb)" },
        { "de": "Das Wetter ist heute schön.", "en": "The weather is nice today.", "note": "Was ist schön? → Das Wetter (subject)" },
        { "de": "Hier wohnt eine alte Frau.", "en": "An old woman lives here.", "note": "Wer wohnt hier? → eine alte Frau (subject)" },
        { "de": "Am Abend liest der Vater ein Buch.", "en": "In the evening the father reads a book.", "note": "Wer liest? → der Vater (subject)" }
      ]
    },
    {
      "id": "gf1-concept-3",
      "heading": "Personal pronouns in the nominative",
      "explanation": "Personal pronouns replace nouns when the subject is already known. German has nine personal pronoun forms in the nominative, including the formal 'Sie' (always capitalised).",
      "table": {
        "headers": ["German", "English", "Example"],
        "rows": [
          ["ich", "I", "Ich lerne Deutsch."],
          ["du", "you (informal sg.)", "Du bist nett."],
          ["er", "he", "Er arbeitet viel."],
          ["es", "it", "Es regnet heute."],
          ["sie", "she", "Sie singt gern."],
          ["wir", "we", "Wir kochen zusammen."],
          ["ihr", "you (informal pl.)", "Ihr seid lustig."],
          ["sie", "they", "Sie spielen Fußball."],
          ["Sie", "you (formal)", "Sie sprechen gut Deutsch."]
        ]
      },
      "examples": [
        { "de": "Ich bin müde.", "en": "I am tired.", "note": "ich = first person singular" },
        { "de": "Wir fahren nach Hamburg.", "en": "We are driving to Hamburg.", "note": "wir = first person plural" },
        { "de": "Sie kommen aus Frankreich.", "en": "They come from France. / You come from France. (formal)", "note": "Context determines meaning" }
      ]
    }
  ],
