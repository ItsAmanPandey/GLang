  "grammar": [
    {
      "topic": "The Modal Verb 'wollen' (to want)",
      "explanation": "Conjugation: ich will, du willst, er/sie/es will, wir wollen, ihr wollt, sie/Sie wollen. The main verb goes at the end in infinitive form. Use 'mÃ¶chten' for a more polite request.",
      "examples": [
        "Ich will nach Deutschland fahren.",
        "Was willst du studieren?",
        "Er will Ingenieur werden.",
        "Wir wollen zusammen feiern."
      ]
    },
    {
      "topic": "Future with 'werden'",
      "explanation": "The simplest way to talk about the future in German is to use the present tense with a time indicator (morgen, nÃ¤chste Woche, etc.). You can also use 'werden' + infinitive for emphasis. Conjugation: ich werde, du wirst, er wird, wir werden, ihr werdet, sie werden.",
      "examples": [
        "Ich werde nÃ¤chstes Jahr studieren.",
        "Du wirst die PrÃ¼fung bestehen.",
        "Wir werden nach Berlin fahren.",
        "Es wird bestimmt klappen."
      ]
    }
