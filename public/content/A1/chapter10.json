  "grammar": [
    {
      "topic": "Giving Directions",
      "explanation": "To give directions, use imperative forms or modal verbs. Key directional words are 'geradeaus' (straight ahead), 'links' (left), and 'rechts' (right).",
      "examples": [
        "Wo ist die Post? â€“ Dort drÃ¼ben.",
        "Das Rathaus ist am Marktplatz.",
        "Die Apotheke ist neben dem Supermarkt.",
        "Das Kino ist gegenÃ¼ber vom Bahnhof."
      ]
    },
    {
      "topic": "Preposition 'mit'",
      "explanation": "When talking about transportation, use 'mit' + Dative case. E.g. 'mit dem Bus' (by bus), 'mit der Bahn' (by train).",
      "examples": [
        "Gehen Sie geradeaus.",
        "Biegen Sie an der Ampel rechts ab.",
        "Die Bank ist auf der linken Seite.",
        "Nehmen Sie die zweite StraÃŸe links."
      ]
    }
