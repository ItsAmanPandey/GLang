  "grammar": [
    {
      "topic": "Expressing Emotions with 'sein' + Adjective",
      "explanation": "You can express emotions in German by using 'sein' + adjective. E.g. 'Ich bin glücklich'. To say what you're happy/angry/sad about, use prepositions: 'über + Akk' (about), 'auf + Akk' (at/about), 'vor + Dat' (of).",
      "examples": [
        "Ich bin glücklich über das Ergebnis.",
        "Er ist wütend auf seinen Bruder.",
        "Sie hat Angst vor Hunden.",
        "Wir sind stolz auf dich."
      ]
    },
    {
      "topic": "Reflexive Verbs for Emotions",
      "explanation": "Many emotional expressions in German use reflexive verbs: sich freuen (über), sich ärgern (über), sich verlieben (in), sich entschuldigen (bei/für). The reflexive pronoun must match the subject.",
      "examples": [
        "Ich freue mich über das Geschenk.",
        "Er ärgert sich über den Lärm.",
        "Sie hat sich in ihn verliebt.",
        "Ich entschuldige mich für den Fehler."
      ]
    }
  ],
