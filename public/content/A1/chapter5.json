  "grammar": [
    {
      "topic": "The Modal Verb 'können'",
      "explanation": "'Können' means 'can' or 'to be able to'. It is irregular: ich kann, du kannst, er/sie kann, wir können, ihr könnt, Sie/sie können.",
      "examples": [
        "Ich kann schwimmen.",
        "Kannst du tanzen?"
      ]
    },
    {
      "topic": "Sentence Structure with Modal Verbs",
      "explanation": "When using 'können', the conjugated modal verb takes position 2. The main action verb goes to the very end of the sentence in its full (infinitive) form.",
      "examples": [
        "Ich kann gut schwimmen.",
        "Wir können am Wochenende Fußball spielen."
      ]
    },
    {
      "topic": "Irregular Verbs (Vowel Change)",
      "explanation": "Verbs like 'lesen' (to read) and 'fahren' (to drive/ride) change their vowel in the 'du' and 'er/sie' forms: du liest, er liest; du fährst, er fährt.",
      "examples": [
        "Ich lese. -> Du liest.",
        "Ich fahre. -> Er fährt."
      ]
    }
  ],
