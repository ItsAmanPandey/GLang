  "title": "Freizeit und Hobbys",
  "subtitle": "Free Time, Hobbies, and the Verb 'koennen'",
  "focus": [
    "Talking about free time and hobbies",
    "Expressing abilities (können)",
    "Months and Seasons",
    "Making suggestions"
  ],
  "tips": [
    {
      "title": "Modal Verb 'können'",
      "body": "When you use a modal verb like 'können' (can), the second verb in the sentence goes to the very end in its infinitive form. Example: Ich kann gut singen."
    },
    {
      "title": "Seasons and Months",
      "body": "Use 'im' (in dem) for seasons and months. Example: im Sommer, im Januar."
    },
    {
      "title": "Noun and Verb combos",
      "body": "Hobbies are often expressed with a noun + verb combo: Fußball spielen, Musik hören, Rad fahren."
    }
  ],
