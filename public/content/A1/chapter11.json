  "grammar": [
    {
      "topic": "Expressing Professions",
      "explanation": "To state your profession in German, you say 'Ich bin [Beruf] von Beruf' or simply 'Ich bin [Beruf]'. You do NOT use the article 'ein/eine' here! E.g. 'Ich bin Lehrer', NOT 'Ich bin ein Lehrer'.",
      "examples": [
        "Ich bin Lehrer.",
        "Sie ist Ärztin.",
        "Er ist Ingenieur von Beruf.",
        "Bist du Student?"
      ]
    },
    {
      "topic": "Masculine vs Feminine Professions",
      "explanation": "Professions almost always have a male and female form. The female form usually ends in '-in' and takes the plural '-innen'. E.g. 'der Lehrer' -> 'die Lehrerin'.",
      "examples": [
        "der Lehrer – die Lehrerin",
        "der Arzt – die Ärztin",
        "der Verkäufer – die Verkäuferin",
        "der Kellner – die Kellnerin"
      ]
    }
  ],
