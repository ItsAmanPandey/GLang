  "grammar": [
    {
      "topic": "Konjugation im Präsens",
      "explanation": "Regular verbs change their endings for ich, du, er/sie, wir, ihr and sie/Sie.",
      "examples": [
        "ich wohne",
        "du arbeitest",
        "wir leben",
        "ihr wohnt"
      ]
    },
    {
      "topic": "sein und haben",
      "explanation": "The verbs sein and haben are irregular and very common for personal information.",
      "examples": [
        "Ich bin Student.",
        "Ihr seid 28 Jahre alt.",
        "Wir haben zwei Kinder.",
        "Sie hat einen Job."
      ]
    },
    {
      "topic": "Negation mit nicht",
      "explanation": "Use nicht to negate many verbs, adjectives or whole statements.",
      "examples": [
        "Wir sind nicht verheiratet.",
        "Ich arbeite im Moment nicht.",
        "Sie wohnen nicht in Berlin."
      ]
    },
    {
      "topic": "kein / keine",
      "explanation": "Use kein before singular masculine or neuter nouns and keine before feminine or plural nouns.",
      "examples": [
        "Ich habe kein Kind.",
        "Wir haben keine Kinder.",
        "Ich habe keinen Partner."
      ]
    },
    {
      "topic": "als, bei, in",
      "explanation": "Use als for a role, bei for an employer, and in for a place.",
      "examples": [
        "Ich arbeite als Kellner.",
        "Sie arbeitet bei HotSped.",
        "Wir wohnen in Fulda."
      ]
    },
    {
      "topic": "Endung -in",
      "explanation": "Many profession words use -in for the feminine form.",
      "examples": [
        "Student - Studentin",
        "Kellner - Kellnerin",
        "Arzt - Ärztin"
      ]
    }
  ],
