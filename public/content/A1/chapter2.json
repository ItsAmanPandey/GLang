  "tips": [
    {
      "title": "als is for the role",
      "body": "Use als before the job: Ich arbeite als Kellner. Use bei before the company: Ich arbeite bei HotSped."
    },
    {
      "title": "nicht negates the sentence",
      "body": "For status and verbs, use nicht: Wir sind nicht verheiratet. Ich arbeite nicht."
    },
    {
      "title": "Learn job pairs together",
      "body": "Many jobs form the feminine with -in: Student/Studentin, Kellner/Kellnerin, Lehrer/Lehrerin."
    }
  ],
